# Required by API server
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required by frontend (set this on Vercel to your deployment URL)
# Base URL for the API server, used by the frontend to make API calls
VITE_API_URL=https://your-vercel-domain.vercel.app

# Replit / local dev only — not needed on Vercel
# Port for the local dev server
PORT=3000

# Replit / local dev only — not needed on Vercel
# Base path prefix for the dev server (e.g. / or /reaper-landscaping)
BASE_PATH=/
